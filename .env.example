# Copy to .env and fill in. Used by docker-compose / finch compose.

# --- Secrets (REQUIRED) ---
# Long random string used to sign session/unlock cookies. Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# Admin login. Username + an argon2 hash of the password (never the plaintext).
# Generate the hash with:
#   docker run --rm node:22-bookworm-slim sh -c "npm i -s argon2 >/dev/null 2>&1; node -e \"require('argon2').hash(process.argv[1]).then(h=>console.log(h))\" 'YOUR_PASSWORD'"
# (or: cd backend && node -e \"require('argon2').hash('YOUR_PASSWORD').then(h=>console.log(h))\")
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=

# --- Persistence (SSD/HDD split) ---
# DATA_PATH → /data: SQLite DB + served variants (full/thumb) + covers + signature
#   + tmp-zips. Latency-sensitive and frequently read → put on SSD.
# ORIGINALS_PATH → /originals: full-resolution uploaded originals (write-once,
#   large, only read on download) → put on HDD (bulk storage).
# Local dev: leave defaults. On TrueNAS: absolute dataset paths, e.g.
#   DATA_PATH=/mnt/ssd-pool/apps/photo-portfolio/data
#   ORIGINALS_PATH=/mnt/hdd-pool/apps/photo-portfolio/originals
# Single-volume setup: set ORIGINALS_PATH to <DATA_PATH>/originals (the default).
DATA_PATH=./data
ORIGINALS_PATH=./data/originals

# --- Networking ---
# Host port nginx (the web service) listens on. Point Nginx Proxy Manager's
# proxy host (thienq.ddnss.de) at http://<truenas-ip>:WEB_PORT.
WEB_PORT=8080

# --- Tunables (optional) ---
# How long a prepared "Download All" zip link stays valid (minutes). The TTL
# clock starts when the zip is ready, not when the build begins. Default 24h.
ZIP_TTL_MINUTES=1440
MAX_UPLOAD_MB=100
FULL_MAX_EDGE=2560
FULL_QUALITY=82
# Album cover hero (kept larger + higher quality than gallery images).
COVER_MAX_EDGE=2880
COVER_QUALITY=88
